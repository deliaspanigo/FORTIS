back_event(TRUE)
})
mod_special_one_show_pdf_server("viewer", file_path = selected_pdf, label = selected_label, zoom = "FitH")
return(list(
goto_back = reactive({ back_event() }),
reset     = function() { back_event(FALSE) }
))
})
}

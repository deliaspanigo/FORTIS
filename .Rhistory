return(NULL)
}
path_www <- find_www()
tkd_files <- if(!is.null(path_www)) {
addResourcePath(ns("tkd_imgs"), file.path(path_www, "fn05_tkd"))
addResourcePath(ns("home_assets"), file.path(path_www, "fn10_home"))
list.files(file.path(path_www, "fn05_tkd"), pattern = "\\.(png|jpg|jpeg|webp)$", ignore.case = TRUE)
} else { character(0) }
tagList(
useShinyjs(),
tags$head(
tags$link(rel = "stylesheet", href = "https://fonts.googleapis.com/css2?family=Orbitron:wght@900&family=Montserrat:wght@300;700;800&display=swap"),
tags$style(HTML(paste0("
body, .container-fluid { padding: 0 !important; margin: 0 !important; overflow: hidden; background: #000; }
#", ns("home_wrapper"), " { width: 100vw; height: 100vh; position: relative; overflow: hidden; font-family: 'Montserrat', sans-serif; }
/* Estilos del Panel de Debug */
.debug-console {
position: absolute; top: 10px; left: 10px; z-index: 999;
background: rgba(0, 212, 255, 0.1); border: 1px solid #00d4ff;
color: #00d4ff; padding: 10px; font-family: 'monospace';
font-size: 10px; border-radius: 4px; pointer-events: none;
text-transform: uppercase; letter-spacing: 1px;
}
.korea-fullscreen { position: absolute; top: 0; left: 0; width: 100vw; height: 100vh; object-fit: contain; z-index: 50; pointer-events: none; }
.brand-box { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); z-index: 100; color: white; text-align: center; display: flex; flex-direction: column; align-items: center; }
.brand-logo { width: 110px; margin-bottom: 18px; }
.title-main { font-family: 'Orbitron'; font-size: 8rem; line-height: 0.82; margin: 0; letter-spacing: -3px; }
.title-sub { margin-top: 10px; font-size: 1.5rem; font-weight: 800; letter-spacing: 10px; color: #00f2fe; text-transform: uppercase; }
.btn-action { margin-top: 30px; background: transparent; color: white; border: 2px solid #00f2fe; padding: 12px 30px; font-family: 'Orbitron'; font-size: 1.2rem; letter-spacing: 2px; transition: all 0.3s ease; cursor: pointer; }
.btn-action:hover { background: #00f2fe; color: #000; box-shadow: 0 0 20px rgba(0, 242, 254, 0.6); }
.bottom-area { position: absolute; inset: 0; display: flex; flex-direction: column; justify-content: space-between; z-index: 5; }
.carousel-track { width: 100%; overflow: hidden; white-space: nowrap; opacity: 0.4; }
.carousel-content { display: inline-flex; align-items: center; }
.carousel-item img { height: 14vh; object-fit: cover; border-right: 1px solid rgba(255,255,255,0.15); }
@keyframes scrollH { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }
.v1 { animation: scrollH 450s linear infinite; } .v2 { animation: scrollH 620s linear infinite; }
.v3 { animation: scrollH 500s linear infinite; } .v4 { animation: scrollH 850s linear infinite; }
.v5 { animation: scrollH 580s linear infinite; } .v6 { animation: scrollH 920s linear infinite; }
.v7 { animation: scrollH 480s linear infinite; }
.footer-container { position: absolute; bottom: 25px; left: 50%; transform: translateX(-50%); z-index: 120; display: flex; flex-direction: column; align-items: center; }
.olympic-logo { width: 220px; opacity: 1; }
.footer-quote { color: white; font-size: 1.82rem; font-weight: 700; letter-spacing: 4px; white-space: nowrap; }
")))
),
div(id = ns("home_wrapper"),
# Visual Debug Overlay
uiOutput(ns("debug_overlay")),
tags$img(src = paste0(ns("home_assets"), "/flag_korea_south_transparent.png"), class = "korea-fullscreen"),
div(class = "brand-box",
tags$img(src = paste0(ns("home_assets"), "/flag_korea_south_transparent.png"), class = "brand-logo"),
h1(class = "title-main", "FORTIS"),
div(class = "title-sub", "TAEKWONDO"),
actionButton(ns("enter_btn"), "Entrar", class = "btn-action")
),
div(class = "bottom-area",
lapply(1:7, function(i) {
if(length(tkd_files) > 0) {
imgs_pool <- rep(sample(tkd_files), 8)
div(class = "carousel-track",
div(class = paste0("carousel-content v", i),
lapply(imgs_pool, function(img) {
div(class = "carousel-item", tags$img(src = paste0(ns("tkd_imgs"), "/", img)))
})
)
)
}
})
),
div(class = "footer-container",
tags$img(src = paste0(ns("home_assets"), "/olympic_ring_transparent_png.png"), class = "olympic-logo"),
div(class = "footer-quote", "CITIUS • ALTIUS • FORTIUS • COMMUNITER")
)
)
)
}
mod_01_home_server <- function(id, debug = TRUE) {
moduleServer(id, function(input, output, session) {
click_data <- reactiveValues(status = FALSE, time = NULL)
observeEvent(input$enter_btn, {
click_data$status <- TRUE
click_data$time <- Sys.time()
})
# Render del Panel de Debug con formato extendido
output$debug_overlay <- renderUI({
req(debug)
# Formateo: %d (día), %m (mes), %Y (año), %H:%M:%S (hora completa)
time_string <- if (is.null(click_data$time)) {
"N/A"
} else {
format(click_data$time, "%d/%m/%Y %H:%M:%S")
}
div(class = "debug-console",
div(style = "font-weight: 800; border-bottom: 1px solid #00d4ff; margin-bottom: 5px;", "Fortis Debug Console"),
div(paste("STATUS  :", ifelse(click_data$status, "ACCESS GRANTED", "WAITING..."))),
div(paste("DATETIME:", time_string)),
div(paste("CLICKS  :", input$enter_btn))
)
})
return(list(
clicked = reactive({ click_data$status }),
time    = reactive({ click_data$time })
))
})
}
